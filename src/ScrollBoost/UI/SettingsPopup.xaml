<Window x:Class="ScrollBoost.UI.SettingsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScrollBoost"
        Width="320" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Border x:Name="RootBorder"
            Background="#202020"
            BorderBrush="#383838"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="Transparent"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,8,0">
                    <TextBlock x:Name="TitleText"
                               Text="ScrollBoost"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="30" Height="30"
                            FontSize="11"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            Foreground="#999999"
                            Background="Transparent"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#999999"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Separator line -->
            <Rectangle Grid.Row="0"
                       x:Name="TitleSeparator"
                       Fill="#383838"
                       Height="1"
                       VerticalAlignment="Bottom"/>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="16,14,16,16">

                <!-- Enabled checkbox -->
                <CheckBox x:Name="EnabledCheck"
                          Margin="0,0,0,16"
                          IsChecked="True"
                          Checked="EnabledCheck_Changed"
                          Unchecked="EnabledCheck_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </CheckBox.Style>
                    <TextBlock x:Name="EnabledLabel"
                               Text="Enabled"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"/>
                </CheckBox>

                <!-- Scroll Speed -->
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="SpeedName"
                               Text="Scroll Speed"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="SpeedLabel"
                               Text="1.5x"
                               Foreground="#60CDFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               FontWeight="Medium"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="SpeedSlider"
                        Minimum="1" Maximum="5"
                        Value="1.5"
                        TickFrequency="0.1"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,14"
                        ValueChanged="Slider_ValueChanged">
                    <Slider.Style>
                        <Style TargetType="Slider">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Slider">
                                        <Grid>
                                            <Track x:Name="PART_Track">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="Slider.DecreaseLarge">
                                                        <RepeatButton.Style>
                                                            <Style TargetType="RepeatButton">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="RepeatButton">
                                                                            <Border x:Name="TrackFill"
                                                                                    Background="#60CDFF"
                                                                                    Height="4"
                                                                                    CornerRadius="2"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </RepeatButton.Style>
                                                    </RepeatButton>
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Style>
                                                            <Style TargetType="Thumb">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Ellipse x:Name="ThumbEllipse"
                                                                                     Width="16" Height="16"
                                                                                     Fill="#60CDFF"/>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Thumb.Style>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="Slider.IncreaseLarge">
                                                        <RepeatButton.Style>
                                                            <Style TargetType="RepeatButton">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="RepeatButton">
                                                                            <Border x:Name="TrackEmpty"
                                                                                    Background="#404040"
                                                                                    Height="4"
                                                                                    CornerRadius="2"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </RepeatButton.Style>
                                                    </RepeatButton>
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Slider.Style>
                </Slider>

                <!-- Acceleration -->
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="AccelName"
                               Text="Acceleration"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="AccelLabel"
                               Text="0.40"
                               Foreground="#60CDFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               FontWeight="Medium"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="AccelSlider"
                        Minimum="0" Maximum="1"
                        Value="0.4"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,14"
                        ValueChanged="Slider_ValueChanged">
                    <Slider.Style>
                        <Style TargetType="Slider">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Slider">
                                        <Grid>
                                            <Track x:Name="PART_Track">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="Slider.DecreaseLarge">
                                                        <RepeatButton.Style>
                                                            <Style TargetType="RepeatButton">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="RepeatButton">
                                                                            <Border Background="#60CDFF" Height="4" CornerRadius="2"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </RepeatButton.Style>
                                                    </RepeatButton>
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Style>
                                                            <Style TargetType="Thumb">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Ellipse x:Name="ThumbEllipse" Width="16" Height="16" Fill="#60CDFF"/>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Thumb.Style>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="Slider.IncreaseLarge">
                                                        <RepeatButton.Style>
                                                            <Style TargetType="RepeatButton">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="RepeatButton">
                                                                            <Border Background="#404040" Height="4" CornerRadius="2"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </RepeatButton.Style>
                                                    </RepeatButton>
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Slider.Style>
                </Slider>

                <!-- Max Speed Cap -->
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="MaxName"
                               Text="Max Speed Cap"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="MaxLabel"
                               Text="12x"
                               Foreground="#60CDFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               FontWeight="Medium"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="MaxSlider"
                        Minimum="2" Maximum="30"
                        Value="12"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,14"
                        ValueChanged="Slider_ValueChanged">
                    <Slider.Style>
                        <Style TargetType="Slider">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Slider">
                                        <Grid>
                                            <Track x:Name="PART_Track">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="Slider.DecreaseLarge">
                                                        <RepeatButton.Style>
                                                            <Style TargetType="RepeatButton">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="RepeatButton">
                                                                            <Border Background="#60CDFF" Height="4" CornerRadius="2"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </RepeatButton.Style>
                                                    </RepeatButton>
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Style>
                                                            <Style TargetType="Thumb">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Ellipse x:Name="ThumbEllipse" Width="16" Height="16" Fill="#60CDFF"/>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Thumb.Style>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="Slider.IncreaseLarge">
                                                        <RepeatButton.Style>
                                                            <Style TargetType="RepeatButton">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="RepeatButton">
                                                                            <Border Background="#404040" Height="4" CornerRadius="2"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </RepeatButton.Style>
                                                    </RepeatButton>
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Slider.Style>
                </Slider>

                <!-- Curve Type -->
                <TextBlock x:Name="CurveLabel"
                           Text="Curve Type"
                           Foreground="#FFFFFF"
                           FontFamily="Segoe UI Variable Text"
                           FontSize="13"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="CurveCombo"
                          SelectedIndex="2"
                          Margin="0,0,0,14"
                          Height="32"
                          SelectionChanged="CurveCombo_Changed">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="BorderBrush" Value="#383838"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton x:Name="ToggleButton"
                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                          Focusable="False">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border x:Name="Bd"
                                                                            Background="#2D2D2D"
                                                                            BorderBrush="#383838"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6">
                                                                        <Grid>
                                                                            <ContentPresenter Margin="10,4,32,4"
                                                                                              VerticalAlignment="Center"/>
                                                                            <TextBlock Text="▾"
                                                                                       Foreground="#999999"
                                                                                       HorizontalAlignment="Right"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,0,10,0"
                                                                                       FontSize="11"/>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#60CDFF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <ContentPresenter x:Name="ContentSite"
                                                              IsHitTestVisible="False"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                              Margin="10,4,32,4"
                                                              VerticalAlignment="Center"/>
                                            <Popup x:Name="Popup"
                                                   Placement="Bottom"
                                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                                   AllowsTransparency="True"
                                                   Focusable="False"
                                                   PopupAnimation="Slide">
                                                <Grid x:Name="DropDown"
                                                      SnapsToDevicePixels="True"
                                                      MinWidth="{TemplateBinding ActualWidth}"
                                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                    <Border x:Name="DropDownBorder"
                                                            Background="#2D2D2D"
                                                            BorderBrush="#383838"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
                                                        </Border.Effect>
                                                    </Border>
                                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Style>
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="4"
                                                Margin="3,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3D3D3D"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A4A6E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                    <ComboBoxItem Content="Linear"/>
                    <ComboBoxItem Content="Power"/>
                    <ComboBoxItem Content="Sigmoid"/>
                </ComboBox>

                <!-- Start with Windows checkbox -->
                <CheckBox x:Name="AutoStartCheck"
                          Checked="AutoStartCheck_Changed"
                          Unchecked="AutoStartCheck_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                            <Setter Property="FontSize" Value="13"/>
                        </Style>
                    </CheckBox.Style>
                    <TextBlock x:Name="AutoStartLabel"
                               Text="Start with Windows"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"/>
                </CheckBox>

            </StackPanel>
        </Grid>
    </Border>
</Window>
