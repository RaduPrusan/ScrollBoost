<Window x:Class="ScrollBoost.UI.SettingsPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScrollBoost"
        Width="320" Height="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#60CDFF"/>
        <SolidColorBrush x:Key="TrackBrush" Color="#404040"/>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#202020"
            BorderBrush="#383838"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    Background="Transparent"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,8,0">
                    <TextBlock x:Name="TitleText"
                               Text="ScrollBoost"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="30" Height="30"
                            FontSize="11"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            Foreground="#999999"
                            Background="Transparent"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#999999"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Separator line -->
            <Rectangle Grid.Row="0"
                       x:Name="TitleSeparator"
                       Fill="#383838"
                       Height="1"
                       VerticalAlignment="Bottom"/>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,14,16,8">

                    <!-- Enabled checkbox -->
                    <CheckBox x:Name="EnabledCheck"
                              Margin="0,0,0,2"
                              IsChecked="True"
                              Checked="EnabledCheck_Changed"
                              Unchecked="EnabledCheck_Changed">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </CheckBox.Style>
                        <TextBlock x:Name="EnabledLabel"
                                   Text="Enabled"
                                   Foreground="#FFFFFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"/>
                    </CheckBox>
                    <TextBlock x:Name="EnabledDesc"
                               Text="Ctrl+Shift+ScrollLock to toggle"
                               Foreground="#999999"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11"
                               Margin="22,2,0,14"/>

                    <!-- Scroll Speed -->
                    <Grid Margin="0,0,0,2">
                        <TextBlock x:Name="SpeedName"
                                   Text="Scroll Speed"
                                   Foreground="#FFFFFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SpeedLabel"
                                   Text="1.5x"
                                   Foreground="#60CDFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock x:Name="SpeedDesc"
                               Text="Base multiplier per scroll notch"
                               Foreground="#999999"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11"
                               Margin="0,2,0,6"/>
                    <Slider x:Name="SpeedSlider"
                            Minimum="1" Maximum="5"
                            Value="1.5"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,14"
                            ValueChanged="Slider_ValueChanged">
                        <Slider.Style>
                            <Style TargetType="Slider">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid>
                                                <Track x:Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="Slider.DecreaseLarge">
                                                            <RepeatButton.Style>
                                                                <Style TargetType="RepeatButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border x:Name="TrackFill"
                                                                                        Background="{DynamicResource AccentBrush}"
                                                                                        Height="4"
                                                                                        CornerRadius="2"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RepeatButton.Style>
                                                        </RepeatButton>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Style>
                                                                <Style TargetType="Thumb">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Ellipse x:Name="ThumbEllipse"
                                                                                         Width="16" Height="16"
                                                                                         Fill="{DynamicResource AccentBrush}"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Thumb.Style>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="Slider.IncreaseLarge">
                                                            <RepeatButton.Style>
                                                                <Style TargetType="RepeatButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border x:Name="TrackEmpty"
                                                                                        Background="{DynamicResource TrackBrush}"
                                                                                        Height="4"
                                                                                        CornerRadius="2"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RepeatButton.Style>
                                                        </RepeatButton>
                                                    </Track.IncreaseRepeatButton>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Slider.Style>
                    </Slider>

                    <!-- Acceleration -->
                    <Grid Margin="0,0,0,2">
                        <TextBlock x:Name="AccelName"
                                   Text="Acceleration"
                                   Foreground="#FFFFFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="AccelLabel"
                                   Text="0.40"
                                   Foreground="#60CDFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock x:Name="AccelDesc"
                               Text="Velocity sensitivity — higher values amplify fast scrolling more"
                               Foreground="#999999"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,2,0,6"/>
                    <Slider x:Name="AccelSlider"
                            Minimum="0" Maximum="1"
                            Value="0.4"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,14"
                            ValueChanged="Slider_ValueChanged">
                        <Slider.Style>
                            <Style TargetType="Slider">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid>
                                                <Track x:Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="Slider.DecreaseLarge">
                                                            <RepeatButton.Style>
                                                                <Style TargetType="RepeatButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border Background="{DynamicResource AccentBrush}" Height="4" CornerRadius="2"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RepeatButton.Style>
                                                        </RepeatButton>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Style>
                                                                <Style TargetType="Thumb">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Ellipse x:Name="ThumbEllipse" Width="16" Height="16" Fill="{DynamicResource AccentBrush}"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Thumb.Style>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="Slider.IncreaseLarge">
                                                            <RepeatButton.Style>
                                                                <Style TargetType="RepeatButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border Background="{DynamicResource TrackBrush}" Height="4" CornerRadius="2"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RepeatButton.Style>
                                                        </RepeatButton>
                                                    </Track.IncreaseRepeatButton>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Slider.Style>
                    </Slider>

                    <!-- Max Speed Cap -->
                    <Grid Margin="0,0,0,2">
                        <TextBlock x:Name="MaxName"
                                   Text="Max Speed Cap"
                                   Foreground="#FFFFFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="MaxLabel"
                                   Text="12x"
                                   Foreground="#60CDFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock x:Name="MaxDesc"
                               Text="Upper limit on the multiplier"
                               Foreground="#999999"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11"
                               Margin="0,2,0,6"/>
                    <Slider x:Name="MaxSlider"
                            Minimum="2" Maximum="30"
                            Value="12"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,14"
                            ValueChanged="Slider_ValueChanged">
                        <Slider.Style>
                            <Style TargetType="Slider">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid>
                                                <Track x:Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="Slider.DecreaseLarge">
                                                            <RepeatButton.Style>
                                                                <Style TargetType="RepeatButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border Background="{DynamicResource AccentBrush}" Height="4" CornerRadius="2"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RepeatButton.Style>
                                                        </RepeatButton>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Style>
                                                                <Style TargetType="Thumb">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Ellipse x:Name="ThumbEllipse" Width="16" Height="16" Fill="{DynamicResource AccentBrush}"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Thumb.Style>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="Slider.IncreaseLarge">
                                                            <RepeatButton.Style>
                                                                <Style TargetType="RepeatButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border Background="{DynamicResource TrackBrush}" Height="4" CornerRadius="2"/>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RepeatButton.Style>
                                                        </RepeatButton>
                                                    </Track.IncreaseRepeatButton>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Slider.Style>
                    </Slider>

                    <!-- Curve Type -->
                    <TextBlock x:Name="CurveLabel"
                               Text="Curve Type"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="13"
                               Margin="0,0,0,2"/>
                    <TextBlock x:Name="CurveDesc"
                               Text="Mathematical shape of the acceleration curve"
                               Foreground="#999999"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="11"
                               Margin="0,2,0,6"/>
                    <ComboBox x:Name="CurveCombo"
                              SelectedIndex="2"
                              Margin="0,0,0,18"
                              Height="32"
                              SelectionChanged="CurveCombo_Changed">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="BorderBrush" Value="#383838"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="10,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton x:Name="ToggleButton"
                                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              Focusable="False">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="Bd"
                                                                                Background="#2D2D2D"
                                                                                BorderBrush="#383838"
                                                                                BorderThickness="1"
                                                                                CornerRadius="6">
                                                                            <Grid>
                                                                                <ContentPresenter Margin="10,4,32,4"
                                                                                                  VerticalAlignment="Center"/>
                                                                                <TextBlock Text="▾"
                                                                                           Foreground="#999999"
                                                                                           HorizontalAlignment="Right"
                                                                                           VerticalAlignment="Center"
                                                                                           Margin="0,0,10,0"
                                                                                           FontSize="11"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60CDFF"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <ContentPresenter x:Name="ContentSite"
                                                                  IsHitTestVisible="False"
                                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                  Margin="10,4,32,4"
                                                                  VerticalAlignment="Center"/>
                                                <Popup x:Name="Popup"
                                                       Placement="Bottom"
                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                       AllowsTransparency="True"
                                                       Focusable="False"
                                                       PopupAnimation="Slide">
                                                    <Grid x:Name="DropDown"
                                                          SnapsToDevicePixels="True"
                                                          MinWidth="{TemplateBinding ActualWidth}"
                                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                        <Border x:Name="DropDownBorder"
                                                                Background="#2D2D2D"
                                                                BorderBrush="#383838"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="4"
                                                    Margin="3,2">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A4A6E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="Linear"/>
                        <ComboBoxItem Content="Power"/>
                        <ComboBoxItem Content="Sigmoid"/>
                    </ComboBox>

                    <!-- Startup section divider -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StartupHeader"
                                   Grid.Column="0"
                                   Text="Startup"
                                   Foreground="#999999"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Rectangle x:Name="StartupDivider"
                                   Grid.Column="1"
                                   Fill="#383838"
                                   Height="1"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Startup: Off -->
                    <RadioButton x:Name="StartupNone"
                                 GroupName="Startup"
                                 Margin="0,0,0,8"
                                 Checked="Startup_Changed">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </RadioButton.Style>
                        <TextBlock Text="Off"
                                   Foreground="#FFFFFF"
                                   FontFamily="Segoe UI Variable Text"
                                   FontSize="13"/>
                    </RadioButton>

                    <!-- Startup: Registry -->
                    <RadioButton x:Name="StartupRegistry"
                                 GroupName="Startup"
                                 Margin="0,0,0,8"
                                 Checked="Startup_Changed">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </RadioButton.Style>
                        <StackPanel>
                            <TextBlock Text="Start with Windows"
                                       Foreground="#FFFFFF"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"/>
                            <TextBlock x:Name="StartupRegistryDesc"
                                       Text="Standard — no UAC prompt. May not work in elevated apps."
                                       Foreground="#999999"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Startup: Scheduler -->
                    <RadioButton x:Name="StartupScheduler"
                                 GroupName="Startup"
                                 Margin="0,0,0,4"
                                 Checked="Startup_Changed">
                        <RadioButton.Style>
                            <Style TargetType="RadioButton">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </RadioButton.Style>
                        <StackPanel>
                            <TextBlock Text="Start elevated"
                                       Foreground="#FFFFFF"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="13"/>
                            <TextBlock x:Name="StartupSchedulerDesc"
                                       Text="Via Task Scheduler — runs as admin with full app coverage."
                                       Foreground="#999999"
                                       FontFamily="Segoe UI Variable Text"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                </StackPanel>
            </ScrollViewer>

            <!-- Version label -->
            <TextBlock Grid.Row="2"
                       x:Name="VersionLabel"
                       Text="ScrollBoost v0.1.0"
                       Foreground="#999999"
                       FontFamily="Segoe UI Variable Text"
                       FontSize="11"
                       HorizontalAlignment="Left"
                       Margin="16,6,16,10"/>

        </Grid>
    </Border>
</Window>
